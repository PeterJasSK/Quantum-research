# Neon pooled connection string (psycopg connects/closes per invocation).
DATABASE_URL=

# Upstash Redis, backs the atomic drbg:counter used for output uniqueness.
REDIS_URL=

# 256-bit quantum master key, hex-encoded (32 bytes = 64 hex chars).
# Sub-keys (e.g. pool-encryption-key, api-key-pepper, receipt-signing-key --
# the EPIC 9 Ed25519 receipt-signing seed -- and drbg-root-encryption-key)
# are HKDF-SHA256-derived from this; it is never written to Neon and never
# used directly as a DRBG seed.
#
# PRODUCTION: generate a fresh value (`python3 -c "import secrets; print(secrets.token_hex(32))"`)
# and store it only in Vercel's env var UI. Never reuse this file's placeholder in production.
#
# EPIC 10: run `python api/scripts/scan_persistence.py` after ingest/deploy to
# confirm nothing plaintext-sensitive was persisted (README "Secure storage & the
# burn lifecycle" section).
MASTER_KEY=

# Bearer token guarding admin-only routes (POST /admin/ingest).
#
# PRODUCTION: generate a fresh value (`python3 -c "import secrets; print(secrets.token_urlsafe(32))"`)
# and store it only in Vercel's env var UI. Never reuse this file's placeholder in production.
ADMIN_TOKEN=

# Comma-separated origins allowed by CORS (web app).
WEB_ORIGIN=http://localhost:3000

# Rate limits, daily ceilings/quotas, and tiers are module constants in
# qeaas/ratelimit.py (no env vars) -- matches the qeaas/keyed_drbg.py reseed constants.
