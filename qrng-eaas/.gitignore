```gitignore
# =========================
# Node / Next.js
# =========================
node_modules/
.next/
out/
build/
dist/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# Python / FastAPI
# =========================
api/venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# IDEs
.idea/

# Secrets
*.pem
*.key
*.crt

# SQLite databases
*.db
*.sqlite3

# Generated uploads (if you create these later)
uploads/
temp/

# Vercel
.vercel/

# Misc
*.swp
*.swo
```
